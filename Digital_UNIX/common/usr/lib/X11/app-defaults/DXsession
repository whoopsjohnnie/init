! From decw_sm_general.dat

*DwtText.translations: #augment \n\
     Ctrl<Key>e:        end-of-line()\n\
     Ctrl<Key>j:        delete-previous-word()\n\
     Ctrl<Key>h:        beginning-of-line()\n\
     Ctrl<Key>r:        redraw-display()\n\
     Ctrl<Key>u:        delete-to-start-of-line()\n

*Stext.translations: #augment \n\
     Ctrl<Key>e:        end-of-line()\n\
     Ctrl<Key>j:        delete-previous-word()\n\
     Ctrl<Key>h:        beginning-of-line()\n\
     Ctrl<Key>r:        redraw-display()\n\
     Ctrl<Key>u:        delete-to-start-of-line()\n

! The following changed to mimic standard login/password behavior.
! These are as close to the translations used by the Xprompter as can be.
*PauseDialog.Password*translations: #override\n\
	<Key>Delete :		delete-previous-character()\n\
	:Ctrl<Key>r :		redraw-display()\n\
	:Ctrl<Key>u :		beginning-of-line() kill-to-end-of-line()\n\
	:Ctrl<Key>w :		delete-next-word()\n\
	Any<Key>:		self-insert()

